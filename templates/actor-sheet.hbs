<div class="mh2-sheet{{#if darkestSelfActive}} mh2-is-darkest{{/if}}">

  <header class="mh2-header">
    <img class="mh2-portrait" data-action="editImage" src="{{actor.img}}" alt="{{actor.name}}" title="Change portrait">
    <div class="mh2-identity">
      <div class="mh2-name-row">
        <input class="mh2-name" type="text" name="name" value="{{actor.name}}" placeholder="Name">
        <a class="mh2-darkest-toggle{{#if darkestSelfActive}} active{{/if}}" data-action="toggleDarkest" title="Toggle Darkest Self">
          <i class="fa-solid fa-moon"></i> {{#if darkestSelfActive}}Darkest Self{{else}}Darkest Self?{{/if}}
        </a>
      </div>
      <div class="mh2-identity-grid">
        <label><span>Skin</span>
          <select class="mh2-skin-picker" title="Pick a skin to apply it to this character">
            {{#if skinMatched}}
            <option value=""></option>
            {{else}}
            <option value="" selected>{{#if system.skin}}{{system.skin}}{{else}}— apply a skin —{{/if}}</option>
            {{/if}}
            {{#each skinOptions}}
            <option value="{{this.id}}"{{#if this.selected}} selected{{/if}}>{{this.name}}</option>
            {{/each}}
          </select>
          {{#if skinItem}}<a class="mh2-btn" data-action="openSkin" title="Open this character's skin"><i class="fa-solid fa-book"></i></a>{{/if}}
        </label>
        <label><span>Look</span><input type="text" name="system.look" value="{{system.look}}" placeholder="guarded, coy…"></label>
        <label><span>Eyes</span><input type="text" name="system.eyes" value="{{system.eyes}}" placeholder="wicked eyes…"></label>
        <label><span>Origin</span><input type="text" name="system.origin" value="{{system.origin}}" placeholder="awoken…"></label>
      </div>
    </div>
  </header>

  <section class="mh2-stats">
    {{#each statList}}
    <div class="mh2-stat">
      <a class="mh2-stat-roll" data-action="rollStat" data-stat="{{this.key}}" title="Roll 2d6 + {{this.label}}">{{this.label}}</a>
      <input type="number" name="system.stats.{{this.key}}" value="{{this.value}}" step="1">
    </div>
    {{/each}}
  </section>

  <section class="mh2-trackers">
    <div class="mh2-track">
      <span class="mh2-track-label">Harm</span>
      <div class="mh2-pips mh2-pips-harm">
        {{#each harmPips}}
        <a class="mh2-pip{{#if this.filled}} filled{{/if}}" data-action="setHarm" data-value="{{this.index}}" title="Harm {{this.index}}"></a>
        {{/each}}
      </div>
    </div>
    <div class="mh2-track">
      <span class="mh2-track-label">Experience</span>
      <div class="mh2-pips mh2-pips-xp">
        {{#each xpPips}}
        <a class="mh2-pip{{#if this.filled}} filled{{/if}}" data-action="setXp" data-value="{{this.index}}" title="XP {{this.index}}"></a>
        {{/each}}
      </div>
      {{#if xpFull}}
      <a class="mh2-btn mh2-btn-text mh2-advance" data-action="advance" title="Spend your full experience track">advance!</a>
      {{/if}}
    </div>
    <div class="mh2-track mh2-bonuses">
      <label title="Applies to every roll until cleared"><span>Ongoing</span>
        <input type="number" name="system.ongoing" value="{{system.ongoing}}" step="1">
      </label>
    </div>
  </section>

  <div class="mh2-body">

    <div class="mh2-columns">

      <section class="mh2-panel mh2-strings">
        <header class="mh2-panel-header">
          <h2>Strings</h2>
          <a class="mh2-btn" data-action="addString" title="Add a String">＋</a>
        </header>
        {{#each system.strings}}
        <div class="mh2-row mh2-string-row">
          <input type="text" name="system.strings.{{@index}}.name" value="{{this.name}}" placeholder="On whom?">
          <a class="mh2-btn" data-action="stringMinus" data-index="{{@index}}" title="Remove one">−</a>
          <input class="mh2-count" type="number" name="system.strings.{{@index}}.count" value="{{this.count}}" step="1" min="0">
          <a class="mh2-btn" data-action="stringPlus" data-index="{{@index}}" title="Add one">＋</a>
          <a class="mh2-btn mh2-spend" data-action="spendString" data-index="{{@index}}" title="Spend a String (posts options to chat)"><i class="fa-solid fa-hand-sparkles"></i></a>
          <a class="mh2-btn mh2-del" data-action="deleteString" data-index="{{@index}}" title="Delete"><i class="fa-solid fa-xmark"></i></a>
        </div>
        {{else}}
        <p class="mh2-empty">No Strings yet. Tragic. Add one.</p>
        {{/each}}
      </section>


      <section class="mh2-panel mh2-conditions">
        <header class="mh2-panel-header">
          <h2>Conditions</h2>
          <a class="mh2-btn" data-action="addCondition" title="Add a Condition">＋</a>
        </header>
        {{#each system.conditions}}
        <div class="mh2-row">
          <input type="text" name="system.conditions.{{@index}}" value="{{this}}" placeholder="drained, terrified…">
          <a class="mh2-btn mh2-del" data-action="deleteCondition" data-index="{{@index}}" title="Delete"><i class="fa-solid fa-xmark"></i></a>
        </div>
        {{else}}
        <p class="mh2-empty">No Conditions. For now.</p>
        {{/each}}
      </section>

    </div>

    <section class="mh2-panel mh2-custom">
      <header class="mh2-panel-header">
        <input class="mh2-custom-label" type="text" name="system.customLabel" value="{{system.customLabel}}" placeholder="Custom tracker — Hungers, Promises…">
        <a class="mh2-btn" data-action="addCustom" title="Add entry">＋</a>
      </header>
      {{#each system.custom}}
      <div class="mh2-row">
        <input type="text" name="system.custom.{{@index}}" value="{{this}}" placeholder="…">
        <a class="mh2-btn mh2-del" data-action="deleteCustom" data-index="{{@index}}" title="Delete"><i class="fa-solid fa-xmark"></i></a>
      </div>
      {{/each}}
    </section>

    <section class="mh2-panel mh2-forwards">
      <header class="mh2-panel-header">
        <h2>Forward</h2>
        <a class="mh2-btn" data-action="addForward" title="Record a conditional +1 forward">＋</a>
      </header>
      <p class="mh2-hint">Conditional one-shots. When you roll, tick the ones that apply — they're consumed on use.</p>
      {{#each system.forwards}}
      <div class="mh2-row mh2-forward-row">
        <input class="mh2-count" type="number" name="system.forwards.{{@index}}.value" value="{{this.value}}" step="1">
        <input type="text" name="system.forwards.{{@index}}.label" value="{{this.label}}" placeholder="e.g. to act on what the abyss showed you">
        <a class="mh2-btn mh2-del" data-action="deleteForward" data-index="{{@index}}" title="Delete"><i class="fa-solid fa-xmark"></i></a>
      </div>
      {{else}}
      <p class="mh2-empty">No Forward held.</p>
      {{/each}}
    </section>

    <section class="mh2-panel mh2-moves">
      <header class="mh2-panel-header">
        <h2>Basic Moves</h2>
        <div class="mh2-panel-actions">
          <a class="mh2-btn mh2-btn-text" data-action="addBasicMoves" title="Seed the six basic moves">basics</a>
          <a class="mh2-btn" data-action="createMove" data-category="basic" title="New basic move">＋</a>
        </div>
      </header>
      {{#each basicMoves}}
      <div class="mh2-move" data-item-id="{{this.id}}">
        <a class="mh2-move-name" data-action="rollMove" title="Roll / post to chat">{{this.name}}</a>
        {{#if this.bonus}}<span class="mh2-move-bonus">{{this.bonusLabel}}</span>{{/if}}
        {{#if this.stat}}
        <span class="mh2-move-stat">{{lookup ../statLabels this.stat}}</span>
        {{else}}
        <span class="mh2-move-stat mh2-move-stat-none">—</span>
        {{/if}}
        <a class="mh2-btn" data-action="editMove" title="Edit"><i class="fa-solid fa-pen"></i></a>
        <a class="mh2-btn mh2-del" data-action="deleteMove" title="Delete"><i class="fa-solid fa-trash"></i></a>
      </div>
      {{else}}
      <p class="mh2-empty">Hit <em>basics</em> to seed the six basic moves.</p>
      {{/each}}
    </section>

    <section class="mh2-panel mh2-moves">
      <header class="mh2-panel-header">
        <h2>Skin Moves</h2>
        <div class="mh2-panel-actions">
          <a class="mh2-btn" data-action="createMove" data-category="skin" title="New skin move">＋</a>
        </div>
      </header>
      {{#if hasSkinMoves}}
      {{#each skinMoveGroups}}
      {{#if this.label}}<h3 class="mh2-subhead">{{this.label}}</h3>{{/if}}
      {{#each this.moves}}
      <div class="mh2-move" data-item-id="{{this.id}}">
        <a class="mh2-move-name" data-action="rollMove" title="Roll / post to chat">{{this.name}}</a>
        {{#if this.bonus}}<span class="mh2-move-bonus">{{this.bonusLabel}}</span>{{/if}}
        {{#if this.stat}}
        <span class="mh2-move-stat">{{lookup ../../statLabels this.stat}}</span>
        {{else}}
        <span class="mh2-move-stat mh2-move-stat-none">—</span>
        {{/if}}
        <a class="mh2-btn" data-action="editMove" title="Edit"><i class="fa-solid fa-pen"></i></a>
        <a class="mh2-btn mh2-del" data-action="deleteMove" title="Delete"><i class="fa-solid fa-trash"></i></a>
      </div>
      {{/each}}
      {{/each}}
      {{else}}
      <p class="mh2-empty">No skin moves yet — your Skin's signature tricks go here.</p>
      {{/if}}
    </section>

    <section class="mh2-panel">
      <header class="mh2-panel-header"><h2>Darkest Self</h2></header>
      <prose-mirror name="system.darkestSelf" value="{{system.darkestSelf}}" toggled>{{{enriched.darkestSelf}}}</prose-mirror>
    </section>

    <section class="mh2-panel">
      <header class="mh2-panel-header"><h2>Sex Move</h2></header>
      <prose-mirror name="system.sexMove" value="{{system.sexMove}}" toggled>{{{enriched.sexMove}}}</prose-mirror>
    </section>

    <section class="mh2-panel">
      <header class="mh2-panel-header"><h2>Backstory</h2></header>
      <prose-mirror name="system.backstory" value="{{system.backstory}}" toggled>{{{enriched.backstory}}}</prose-mirror>
    </section>

    <section class="mh2-panel">
      <header class="mh2-panel-header"><h2>Advancements</h2></header>
      <input type="text" name="system.advancements" value="{{system.advancements}}" placeholder="e.g. +1 Dark · took Sanctuary · …">
    </section>

    <section class="mh2-panel">
      <header class="mh2-panel-header"><h2>Notes</h2></header>
      <prose-mirror name="system.notes" value="{{system.notes}}" toggled>{{{enriched.notes}}}</prose-mirror>
    </section>

  </div>
</div>
